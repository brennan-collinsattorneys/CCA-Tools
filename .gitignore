# Spec Kit / agent runtime
.specify/feature.json

# OS / editor cruft
Thumbs.db
.DS_Store
*.swp

# Local environment / secrets (do not commit tenant credentials)
*.env
.env
.env.*
config/lkos-settings.local.json

# Certificates / private keys (never commit)
*.pfx
*.cer
*.pem
*.key

# Populated matter inventory may contain client PII — keep only the templates
inventory/matter-inventory.xlsx
inventory/*.draft.csv
inventory/*.draft.xlsx

# PowerShell module output / logs
*.log
